{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "target": "ES2023",

    "types": ["node"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },

  "include": [
    "src",
    "generated"
  ]
}